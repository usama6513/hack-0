{
  "api_errors": {
    "patterns": [
      "API error",
      "Connection failed",
      "Rate limit",
      "429",
      "503"
    ],
    "recovery": "wait_and_retry"
  },
  "auth_errors": {
    "patterns": [
      "Authentication failed",
      "Invalid token",
      "Session expired",
      "401",
      "403"
    ],
    "recovery": "re_authenticate"
  },
  "network_errors": {
    "patterns": [
      "Network error",
      "Timeout",
      "Connection refused",
      "DNS error"
    ],
    "recovery": "check_connection"
  },
  "file_errors": {
    "patterns": [
      "File not found",
      "Permission denied",
      "Disk full",
      "IO error"
    ],
    "recovery": "use_backup"
  },
  "service_errors": {
    "patterns": [
      "Service unavailable",
      "Internal error",
      "500 error"
    ],
    "recovery": "use_fallback"
  }
}